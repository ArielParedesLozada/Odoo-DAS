<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_slide_channel_form_inherit_das_lms_certificates" model="ir.ui.view">
        <field name="name">slide.channel.form.inherit.das.lms.certificates</field>
        <field name="model">slide.channel</field>
        <field name="inherit_id" ref="website_slides.view_slide_channel_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_generate_certification_flow" 
                        type="object" 
                        string="Generar Evaluaciones de Certificación" 
                        class="oe_highlight btn-info"
                        confirm="Esto creará automáticamente el Examen Final y la Encuesta de Satisfacción para este curso. ¿Deseas continuar?"/>
            </xpath>
        </field>
    </record>
</odoo>
