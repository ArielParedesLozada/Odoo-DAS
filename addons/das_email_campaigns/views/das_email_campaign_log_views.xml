<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="das_email_campaign_log_view_list" model="ir.ui.view">
        <field name="name">das.email.campaign.log.list</field>
        <field name="model">das.email.campaign.log</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'sent'" decoration-danger="state == 'failed'" decoration-muted="state == 'queued'">
                <field name="create_date" string="Registrado"/>
                <field name="config_id" string="Campaña"/>
                <field name="campaign_type" optional="show"/>
                <field name="partner_id" string="Contacto"/>
                <field name="channel_id" optional="show" string="Curso"/>
                <field name="period_key"/>
                <field name="mailing_id" optional="hide"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'sent'"
                    decoration-danger="state == 'failed'"
                    decoration-info="state == 'queued'"/>
                <field name="trace_status" string="Entrega" widget="badge" optional="show"/>
                <field name="sent_at" optional="show"/>
            </list>
        </field>
    </record>

    <record id="das_email_campaign_log_view_form" model="ir.ui.view">
        <field name="name">das.email.campaign.log.form</field>
        <field name="model">das.email.campaign.log</field>
        <field name="arch" type="xml">
            <form create="0" edit="0">
                <sheet>
                    <group>
                        <group string="Campaña y contacto">
                            <field name="config_id"/>
                            <field name="campaign_type"/>
                            <field name="partner_id"/>
                            <field name="channel_id"/>
                            <field name="period_key"/>
                        </group>
                        <group string="Envío y entrega">
                            <field name="mailing_id"/>
                            <field name="state"/>
                            <field name="trace_status"/>
                            <field name="sent_at"/>
                            <field name="create_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="das_email_campaign_log_view_search" model="ir.ui.view">
        <field name="name">das.email.campaign.log.search</field>
        <field name="model">das.email.campaign.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id" string="Contacto" filter_domain="[('partner_id', 'ilike', self)]"/>
                <field name="config_id" string="Campaña"/>
                <field name="campaign_type" string="Tipo"/>
                <field name="channel_id" string="Curso"/>
                <field name="period_key" string="Periodo"/>
                <field name="state" string="Estado envío"/>
                <field name="trace_status" string="Estado entrega"/>
                <separator/>
                <filter string="Enviados" name="sent" domain="[('state', '=', 'sent')]"/>
                <filter string="En cola" name="queued" domain="[('state', '=', 'queued')]"/>
                <filter string="Fallidos" name="failed" domain="[('state', '=', 'failed')]"/>
                <separator/>
                <filter string="Cumpleaños" name="type_birthday" domain="[('campaign_type', '=', 'birthday')]"/>
                <filter string="Cursos próximos" name="type_upcoming" domain="[('campaign_type', '=', 'upcoming')]"/>
                <filter string="Cursos nuevos" name="type_new" domain="[('campaign_type', '=', 'new_courses')]"/>
                <filter string="Por nivel" name="type_experience" domain="[('campaign_type', '=', 'experience')]"/>
                <filter string="Newsletter" name="type_newsletter" domain="[('campaign_type', '=', 'newsletter')]"/>
                <separator/>
                <filter string="Entrega: enviado" name="trace_sent" domain="[('trace_status', '=', 'sent')]"/>
                <filter string="Entrega: abierto" name="trace_open" domain="[('trace_status', '=', 'open')]"/>
                <filter string="Entrega: rebotado" name="trace_bounce" domain="[('trace_status', '=', 'bounce')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Campaña" name="group_config" context="{'group_by': 'config_id'}"/>
                    <filter string="Contacto" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Estado de envío" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Estado de entrega" name="group_trace" context="{'group_by': 'trace_status'}"/>
                    <filter string="Periodo" name="group_period" context="{'group_by': 'period_key'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="das_email_campaign_log_action" model="ir.actions.act_window">
        <field name="name">Registro de envíos automáticos</field>
        <field name="res_model">das.email.campaign.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="das_email_campaign_log_view_search"/>
        <field name="context">{'search_default_group_config': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aquí aparece cada envío automático DAS: contacto, campaña, periodo y estado de entrega.
            </p>
            <p>
                Filtra por campaña, contacto o estado. La sincronización con
                <strong>mailing.trace</strong> se actualiza por cron y al completar cada correo masivo.
            </p>
        </field>
    </record>
</odoo>
