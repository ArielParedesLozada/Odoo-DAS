<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="das_email_campaign_config_view_list" model="ir.ui.view">
        <field name="name">das.email.campaign.config.list</field>
        <field name="model">das.email.campaign.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="cron_interval"/>
                <field name="active"/>
                <field name="last_run_date"/>
                <field name="log_count"/>
            </list>
        </field>
    </record>

    <record id="das_email_campaign_config_view_form" model="ir.ui.view">
        <field name="name">das.email.campaign.config.form</field>
        <field name="model">das.email.campaign.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_logs" type="object" class="oe_stat_button" icon="fa-envelope">
                            <field name="log_count" widget="statinfo" string="Envíos"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active"/>
                            <field name="cron_interval"/>
                            <field name="mail_template_id"/>
                        </group>
                        <group>
                            <field name="days_before_start" invisible="code != 'upcoming'"/>
                            <field name="new_course_window_days" invisible="code != 'new_courses'"/>
                            <field name="last_run_date" readonly="1"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="das_email_campaign_config_action" model="ir.actions.act_window">
        <field name="name">Campañas automáticas</field>
        <field name="res_model">das.email.campaign.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
