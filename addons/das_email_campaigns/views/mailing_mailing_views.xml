<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mailing_mailing_form_das_campaigns" model="ir.ui.view">
        <field name="name">mailing.mailing.form.das.campaigns</field>
        <field name="model">mailing.mailing</field>
        <field name="inherit_id" ref="mass_mailing.view_mail_mass_mailing_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_test']" position="after">
                <button name="action_das_preview_rendered" type="object"
                        string="Vista previa real"
                        class="btn-secondary"
                        invisible="not body_html"
                        title="Muestra el correo con nombre y logo reales"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_das_campaign_logs" type="object"
                        class="oe_stat_button" icon="fa-list"
                        invisible="not das_campaign_config_id">
                    <field name="das_campaign_log_count" widget="statinfo" string="Log DAS"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='campaign_id']" position="after">
                <field name="das_campaign_config_id" readonly="1"/>
                <field name="das_campaign_period_key" readonly="1"/>
                <field name="das_campaign_channel_id" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
