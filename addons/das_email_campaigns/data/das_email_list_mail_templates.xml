<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">
    <!-- Plantillas para envío manual desde listas de correo (modelo mailing.contact) -->

    <record id="mail_template_das_list_newsletter" model="mail.template">
        <field name="name">DAS · Lista · Newsletter general</field>
        <field name="model_id" ref="mass_mailing.model_mailing_contact"/>
        <field name="subject">🎓 Novedades en Academia Virtual DAS</field>
        <field name="body_html" type="html">
<table cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f1f5f9;font-family:Arial,Helvetica,sans-serif;">
    <tr><td align="center" style="padding:24px 12px;">
        <table cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 16px rgba(15,23,42,0.08);">
            <tr><td style="background:linear-gradient(135deg,#1e3a8a,#2563eb);padding:28px 24px;text-align:center;">
                <img src="/das_email_preferences/static/src/img/Logo.png" alt="Academia Virtual DAS" style="max-width:150px;height:auto;"/>
            </td></tr>
            <tr><td style="padding:32px 28px;color:#1e293b;font-size:15px;line-height:1.6;">
                <p style="margin:0 0 16px;">Hola <strong>{{ object.name }}</strong>,</p>
                <p style="margin:0 0 16px;">Te compartimos las <strong>novedades destacadas</strong> de Academia Virtual DAS: nuevos cursos, talleres y oportunidades de formación pensadas para ti.</p>
                <p style="margin:0 0 20px;">Explora la plataforma y descubre contenido actualizado según tus intereses.</p>
                <p style="margin:0;text-align:center;">
                    <a href="/slides" style="display:inline-block;background:#2563eb;color:#ffffff;text-decoration:none;padding:12px 28px;border-radius:8px;font-weight:bold;">Ver cursos disponibles</a>
                </p>
            </td></tr>
            <tr><td style="background:#f8fafc;padding:16px 28px;text-align:center;font-size:12px;color:#64748b;">
                Academia Virtual DAS · Comunicación por email
            </td></tr>
        </table>
    </td></tr>
</table>
        </field>
    </record>

