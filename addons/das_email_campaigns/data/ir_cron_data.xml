<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_das_email_campaigns_daily" model="ir.cron">
        <field name="name">DAS: campañas email diarias</field>
        <field name="model_id" ref="model_das_email_campaign_config"/>
        <field name="state">code</field>
        <field name="code">model.cron_run_daily_campaigns()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_das_email_campaigns_weekly" model="ir.cron">
        <field name="name">DAS: campañas email semanales</field>
        <field name="model_id" ref="model_das_email_campaign_config"/>
        <field name="state">code</field>
        <field name="code">model.cron_run_weekly_campaigns()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">weeks</field>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_das_email_campaigns_monthly" model="ir.cron">
        <field name="name">DAS: campañas email mensuales</field>
        <field name="model_id" ref="model_das_email_campaign_config"/>
        <field name="state">code</field>
        <field name="code">model.cron_run_monthly_campaigns()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_das_email_campaigns_sync_traces" model="ir.cron">
        <field name="name">DAS: sincronizar entregas de campañas</field>
        <field name="model_id" ref="model_das_email_campaign_log"/>
        <field name="state">code</field>
        <field name="code">model._cron_sync_delivery_status()</field>
        <field name="interval_number">6</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
