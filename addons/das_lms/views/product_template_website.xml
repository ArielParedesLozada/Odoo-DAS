<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Marca la ficha: CSS + JS pueden ocultar carrito aunque el mixin de Odoo vuelva a poner d-inline-flex. -->
    <template id="product_template_das_lms_cta" inherit_id="website_sale.product" priority="120">
        <xpath expr="//section[@id='product_detail']" position="attributes">
            <attribute name="t-att-data-das-lms-hide-shop">'1' if (combination_info.get('prevent_zero_price_sale') or das_lms_hide_add_to_cart or das_lms_shop_enrolled or product._das_lms_is_enrolled_in_course() or product._das_lms_fallback_hide_shop_cart() or product._das_lms_course_sale_blocked()) else ''</attribute>
            <attribute name="t-att-data-das-lms-notice-stack-cart">'1' if product._das_lms_course_sale_notice_stacks_cart() else ''</attribute>
        </xpath>
        <xpath expr="//div[@id='add_to_cart_wrap']" position="before">
            <!-- Depuración: solo si el controlador inyectó das_lms_debug_show (editor/admin web) -->
            <div class="container px-0" t-if="das_lms_debug_show">
                <t t-out="das_lms_debug_html"/>
            </div>
            <!-- Bloque único inscrito: verde (activo), celeste (próximo), gris (finalizado). -->
            <div
                t-if="das_lms_shop_enrolled or product._das_lms_is_enrolled_in_course()"
                t-attf-class="{{ product._das_lms_shop_enrolled_banner_alert_classes() }}"
                role="status"
            >
                <i
                    t-attf-class="{{ product._das_lms_shop_enrolled_banner_icon_classes() }} fa-lg me-2 mt-1 flex-shrink-0"
                    role="presentation"
                />
                <div class="flex-grow-1 min-w-0">
                    <span class="d-block fw-semibold mb-1" t-out="product._das_lms_shop_enrolled_banner_title()"/>
                    <span class="d-block small mb-3" t-out="product._das_lms_shop_enrolled_banner_body()"/>
                    <a
                        t-att-href="product._das_lms_course_website_url()"
                        class="btn btn-primary d-inline-flex align-items-center"
                    >
                        <i t-attf-class="{{ product._das_lms_shop_enrolled_banner_btn_icon_classes() }}"/>
                        <span t-out="product._das_lms_course_portal_cta_label()"/>
                    </a>
                </div>
            </div>
            <!-- Visitante no inscrito: aviso dinámico de inscripción (amarillo / gris) -->
            <div
                t-if="product._das_lms_course_sale_notice_html() and not (das_lms_shop_enrolled or product._das_lms_is_enrolled_in_course())"
                t-attf-class="{{ product._das_lms_course_sale_notice_alert_classes() }} {{ 'o_das_lms_product_notice--stack w-100' if product._das_lms_course_sale_notice_stacks_cart() else '' }}"
                role="status"
            >
                <i
                    t-attf-class="fa fa-lg me-2 mt-1 flex-shrink-0 {{ 'fa-ban text-secondary' if product._das_lms_course_sale_notice_kind() == 'closed' else 'fa-exclamation-triangle text-warning' }}"
                    role="presentation"
                />
                <span class="small mb-0" t-out="product._das_lms_course_sale_notice_html()"/>
            </div>
        </xpath>
        <xpath expr="//div[@id='add_to_cart_wrap']" position="attributes">
            <attribute name="t-attf-class">{{'d-none' if combination_info.get('prevent_zero_price_sale') or das_lms_hide_add_to_cart or das_lms_shop_enrolled or product._das_lms_is_enrolled_in_course() or product._das_lms_fallback_hide_shop_cart() or product._das_lms_course_sale_blocked() else ('d-inline-flex mt-2 mb-2 o_das_lms_add_to_cart--below_notice' if product._das_lms_course_sale_notice_stacks_cart() else 'd-inline-flex')}} align-items-center mb-2 me-auto</attribute>
        </xpath>
    </template>

    <!-- Precio: ocultar en ficha cuando ya está inscrito (misma UX que curso activo). -->
    <template id="product_price_das_lms_hide_enrolled" inherit_id="website_sale.product_price" priority="120">
        <xpath expr="//div[@itemprop='offers']" position="attributes">
            <attribute name="t-attf-class">product_price mt-2 mb-3 {{'d-none' if combination_info.get('prevent_zero_price_sale') or product._das_lms_is_enrolled_in_course() else 'd-inline-block'}}</attribute>
        </xpath>
    </template>

    <!-- Cantidad: misma regla que carrito (website_sale.product_quantity inserta este bloque). -->
    <template id="product_quantity_das_lms_hide_enrolled" inherit_id="website_sale.product_quantity" priority="120">
        <xpath expr="//div[contains(@t-attf-class, 'css_quantity')]" position="attributes">
            <attribute name="t-attf-class">css_quantity input-group {{'d-none' if combination_info.get('prevent_zero_price_sale') or combination_info.get('das_lms_course_qty_fixed') or das_lms_hide_add_to_cart or das_lms_shop_enrolled or product._das_lms_is_enrolled_in_course() or product._das_lms_fallback_hide_shop_cart() or product._das_lms_course_sale_blocked() else 'd-inline-flex'}} me-2 mb-2 align-middle</attribute>
        </xpath>
    </template>
</odoo>
