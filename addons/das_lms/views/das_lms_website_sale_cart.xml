<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Curso LMS: cantidad fija 1 en carrito (sin +/- que provoquen error HTTP). -->
    <template id="cart_lines_das_lms_qty" inherit_id="website_sale.cart_lines" priority="35">
        <xpath expr="//div[@name='website_sale_cart_line_quantity']" position="replace">
            <div
                name="website_sale_cart_line_quantity"
                t-attf-class="{{'mb-2 o_das_lms_cart_qty_fixed text-end w-100' if line._das_lms_is_course_line() else 'css_quantity input-group mb-2'}}"
            >
                <t t-if="line._das_lms_is_course_line()">
                    <span class="badge text-bg-light border px-3 py-2">1</span>
                    <input
                        type="hidden"
                        class="js_quantity quantity form-control"
                        t-att-data-line-id="line.id"
                        t-att-data-product-id="line.product_id.id"
                        value="1"
                    />
                    <small class="text-muted d-block mt-1" style="max-width: 11rem;">
                        Cantidad fija para cursos.
                    </small>
                </t>
                <t t-else="">
                    <t t-if="not line._is_not_sellable_line()">
                        <t t-if="show_qty">
                            <a
                                href="#"
                                class="js_add_cart_json btn btn-link d-inline-block border-end-0"
                                aria-label="Remove one"
                                title="Remove one"
                            >
                                <i class="position-relative z-1 fa fa-minus"/>
                            </a>
                            <input
                                type="text"
                                class="js_quantity quantity form-control border-start-0 border-end-0"
                                t-att-data-line-id="line.id"
                                t-att-data-product-id="line.product_id.id"
                                t-att-value="line._get_displayed_quantity()"
                            />
                            <t t-if="line._get_shop_warning(clear=False)">
                                <a href="#" class="btn btn-link">
                                    <i
                                        class="fa fa-warning text-warning"
                                        t-att-title="line._get_shop_warning()"
                                        role="img"
                                        aria-label="Warning"
                                    />
                                </a>
                            </t>
                            <a
                                t-else=""
                                href="#"
                                class="js_add_cart_json d-inline-block float_left btn btn-link border-start-0"
                                aria-label="Add one"
                                title="Add one"
                            >
                                <i class="fa fa-plus position-relative z-1"/>
                            </a>
                        </t>
                        <t t-else="">
                            <input
                                type="hidden"
                                class="js_quantity form-control quantity"
                                t-att-data-line-id="line.id"
                                t-att-data-product-id="line.product_id.id"
                                t-att-value="line._get_displayed_quantity()"
                            />
                        </t>
                    </t>
                    <t t-else="">
                        <span class="w-100 text-muted" t-esc="int(line.product_uom_qty)"/>
                        <input
                            type="hidden"
                            class="js_quantity quantity form-control"
                            t-att-data-line-id="line.id"
                            t-att-data-product-id="line.product_id.id"
                            t-att-value="line._get_displayed_quantity()"
                        />
                    </t>
                </t>
            </div>
        </xpath>
    </template>

    <template id="cart_warning_label_das_lms" inherit_id="website_sale.cart_lines" priority="36">
        <xpath expr="//div[contains(@class,'alert-warning') and contains(@class,'js_cart_lines')]//strong" position="replace">
            <strong>Aviso</strong>
        </xpath>
    </template>
</odoo>
