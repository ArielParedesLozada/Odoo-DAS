<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_das_lms_invoice_enroll_backfill_form" model="ir.ui.view">
        <field name="name">das.lms.invoice.enroll.backfill.form</field>
        <field name="model">das.lms.invoice.enroll.backfill</field>
        <field name="arch" type="xml">
            <form string="Inscribir desde facturas publicadas">
                <group>
                    <div class="alert alert-warning mb-0" role="alert">
                        Recorre todas las facturas de cliente ya validadas, resuelve productos ↔ cursos por vínculo
                        estructurado y crea las inscripciones <code>slide.channel.partner</code> faltantes.
                        Solo administradores.
                    </div>
                </group>
                <footer>
                    <button name="action_execute" string="Ejecutar" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_das_lms_invoice_enroll_backfill_wizard" model="ir.actions.act_window">
        <field name="name">Inscribir desde facturas publicadas</field>
        <field name="res_model">das.lms.invoice.enroll.backfill</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_das_lms_invoice_enroll_backfill"
        name="Inscribir desde facturas publicadas"
        parent="menu_das_lms_root"
        action="action_das_lms_invoice_enroll_backfill_wizard"
        sequence="65"
        groups="base.group_system,base.group_erp_manager"
    />
</odoo>
