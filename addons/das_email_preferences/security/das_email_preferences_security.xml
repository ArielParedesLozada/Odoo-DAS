<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_das_email_preferences" model="ir.module.category">
        <field name="name">DAS Preferencias Email</field>
        <field name="sequence">45</field>
    </record>

    <record id="group_das_email_preferences_user" model="res.groups">
        <field name="name">Usuario: ver propias preferencias</field>
        <field name="category_id" ref="module_category_das_email_preferences"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_das_email_preferences_marketing" model="res.groups">
        <field name="name">Marketing: gestionar preferencias</field>
        <field name="category_id" ref="module_category_das_email_preferences"/>
        <field name="implied_ids" eval="[(4, ref('mass_mailing.group_mass_mailing_user'))]"/>
    </record>

    <record id="das_email_preference_rule_own" model="ir.rule">
        <field name="name">Preferencias: propio contacto</field>
        <field name="model_id" ref="model_das_email_preference"/>
        <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal')), (4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="das_email_preference_rule_marketing" model="ir.rule">
        <field name="name">Preferencias: marketing ve todo</field>
        <field name="model_id" ref="model_das_email_preference"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_das_email_preferences_marketing'))]"/>
    </record>
</odoo>
