# ============================================================
# Variables de entorno — copia a .env y completa los valores
# NUNCA commites .env (ya está en .gitignore)
# ============================================================

# ── Docker image ─────────────────────────────────────────────
DOCKER_IMAGE=odoo-das
IMAGE_TAG=latest

# ── Base de datos ────────────────────────────────────────────
DB_NAME=odoo_prod
DB_USER=odoo
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO

# ── Odoo ─────────────────────────────────────────────────────
# Hash pbkdf2 — generar con:
# python3 -c "from passlib.context import CryptContext; print(CryptContext(['pbkdf2_sha512']).hash('TU_PASSWORD'))"
ADMIN_PASSWD_HASH=CAMBIAR_POR_HASH

# ── Email (SMTP saliente) ────────────────────────────────────
EMAIL_MAIL=tu-correo@gmail.com
EMAIL_PASSWORD=CAMBIAR_APP_PASSWORD_GMAIL

# ── Dominio (usado en nginx.conf y certificados SSL) ─────────
DOMAIN=odoo.tudominio.com
STAGING_DOMAIN=staging.tudominio.com
CERTBOT_EMAIL=tu-correo@tudominio.com

# ── GitHub Container Registry ────────────────────────────────
GHCR_REGISTRY=ghcr.io
GHCR_REPO=tu-usuario/odoo-das
